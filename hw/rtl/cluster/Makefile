# Makefile for Cocotb Simulation of NPU Cluster

SIM ?= verilator
TOPLEVEL_LANG ?= verilog
VERILATOR_JOBS ?= 8

PWD=$(shell pwd)
REPO_ROOT=$(PWD)/../../..

# All RTL sources declared in snitch_minimal.F (template, uses $(REPO_ROOT))
# Expanded into snitch_expanded.F before passing to verilator.
SNITCH_F_TEMPLATE = $(PWD)/snitch_minimal.F
SNITCH_F_EXPANDED = $(PWD)/tb/sim/$(MODULE)/snitch_expanded.F

# Generate expanded .F (replace $(REPO_ROOT) with actual path)
gen_f:
	@mkdir -p $(PWD)/tb/sim/$(MODULE)
	@sed 's|\$$(REPO_ROOT)|$(REPO_ROOT)|g' $(SNITCH_F_TEMPLATE) > $(SNITCH_F_EXPANDED)

# MODULE is the basename of the Python test file
export PYTHONPATH := $(PWD)/tb:$(PWD)/tb/tests:$(PYTHONPATH)
# Python test module
COCOTB_TEST_MODULES ?= test_snitch_boot
MODULE = $(COCOTB_TEST_MODULES)

# Set build directory to tb/sim/<test_name>
SIM_BUILD = $(PWD)/tb/sim/$(MODULE)

# TOPLEVEL is the name of the toplevel module in your Verilog
TOPLEVEL = tb_npu_cluster

# Cocotb requires at least one file in VERILOG_SOURCES to trigger build.
# All actual sources are in snitch_expanded.F via EXTRA_ARGS.
# We use the toplevel file as the "anchor" so verilator sees the module.
VERILOG_SOURCES = $(PWD)/tb/tb_npu_cluster.sv

# Verilator extra args: pass expanded .F which contains all other sources
EXTRA_ARGS += -Wno-fatal -Wno-WIDTH -Wno-UNOPTFLAT -Wno-IMPLICIT -Wno-PINMISSING \
              --timing -DSNITCH_ENABLE_PERF -j $(VERILATOR_JOBS)

# Cocotb's Verilator backend invokes `make -C $(SIM_BUILD) ... -f Vtop.mk`.
# Pass `-j` into that generated C++ build as well; Verilator's `-j` only
# parallelizes the Verilator frontend, not the generated model compilation.
BUILD_ARGS += -j$(VERILATOR_JOBS)

# Inject the expanded file list (will be generated by gen_f before sim)
ifneq ($(wildcard $(SNITCH_F_EXPANDED)),)
EXTRA_ARGS += -f $(SNITCH_F_EXPANDED)
endif

# Enable VCD dumping if DEBUG=1
DEBUG ?= 0
ifeq ($(DEBUG), 1)
    EXTRA_ARGS += --trace
    export WAVES = 1
endif

# Include Cocotb's make rules
include $(shell cocotb-config --makefiles)/Makefile.sim

# Override sim target to always regenerate .F first
sim: gen_f

# Clean output dir
clean::
	@rm -rf tb/sim __pycache__ tb/__pycache__ results.xml dump.vcd
